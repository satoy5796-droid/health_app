<!-- app/views/my_pages/advice_history.html.erb -->
<div class="max-w-4xl mx-auto py-6 space-y-8">
  
  <!-- ヘッダーエリア -->
  <div class="border-b border-gray-200 pb-5 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 tracking-tight">AIアドバイス履歴</h1>
      <p class="mt-1 text-sm text-gray-500">過去にAIコーチから届いた大切なアドバイスのストックです。</p>
    </div>
    <div class="text-sm font-medium bg-blue-50 text-blue-700 px-3 py-1.5 rounded-full border border-blue-100 self-start md:self-center">
      ストック数: <span class="font-bold"><%= @all_advice_records.count %></span> 件
    </div>
  </div>

  <!-- 検索フォームセクション -->
  <div class="bg-white p-4 rounded-xl shadow-sm border border-gray-100">
    <%= form_with url: mypage_advices_path, method: :get, local: true, class: "flex gap-2" do |f| %>
      <div class="relative flex-grow">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-gray-400">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        </div>
        <%= f.text_field :q, value: params[:q], placeholder: "アドバイス内容や食事、キーワードで検索...", class: "w-full pl-10 pr-4 py-2 rounded-lg border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm" %>
      </div>
      <%= f.submit "検索", class: "bg-gray-900 hover:bg-gray-800 text-white font-bold px-5 py-2 rounded-lg text-sm shadow-sm cursor-pointer transition" %>
      <% if params[:q].present? %>
        <%= link_to "クリア", mypage_advices_path, class: "border border-gray-200 hover:bg-gray-50 text-gray-600 px-3 py-2 rounded-lg text-sm flex items-center transition" %>
      <% end %>
    <% end %>
  </div>

  <!-- 条件分岐: データが存在する場合 -->
  <% if @all_advice_records.any? %>
    <div class="grid grid-cols-1 gap-4">
      
      <% start_index = (@current_page - 1) * 10 %>
      <% current_page_advices = @all_advice_records.drop(start_index).take(10) %>

      <% current_page_advices.each do |record| %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-5 md:p-6 transition hover:shadow-md space-y-4">
          
          <!-- カード上部: 日付と体調・睡眠データ -->
          <div class="flex flex-wrap items-center justify-between gap-2 border-b border-gray-50 pb-3">
            <div class="flex items-center gap-3">
              <span class="text-sm font-bold text-gray-900"><%= l(record.recorded_on, format: :long) rescue record.recorded_on %></span>
              
              <!-- ⭕ 修正ポイント: バグの元だったcase文を関数1行に置き換えて安全化 -->
              <%= condition_badge(record.condition) %>
              
              <span class="text-xs text-gray-500">😴 <%= record.sleep_time %>時間</span>
            </div>
            <%= link_to "この日の全記録を見る", health_record_path(record), data: { turbo: false }, class: "text-xs text-blue-600 hover:underline font-semibold" %>
          </div>

          <!-- カード中部: AIアドバイス内容 -->
          <div class="flex gap-3 bg-blue-50/40 p-4 rounded-xl border border-blue-100/50">
            <div class="text-2xl select-none">🤖</div>
            <div class="space-y-1">
              <div class="text-xs font-bold text-blue-800">AIコーチからの助言</div>
              <p class="text-sm text-gray-700 leading-relaxed font-medium"><%= record.ai_advice %></p>
            </div>
          </div>

          <!-- カード下部: その日の食事メモ -->
          <% if record.breakfast_memo.present? || record.lunch_memo.present? || record.dinner_memo.present? %>
            <div class="text-[11px] text-gray-400 flex flex-wrap gap-x-4 gap-y-1 bg-gray-50/50 p-2 rounded-lg">
              <% if record.breakfast_memo.present? %>
                <div>☀️ <span class="font-medium text-gray-500">朝:</span> <%= truncate(record.breakfast_memo, length: 15) %></div>
              <% end %>
              <% if record.lunch_memo.present? %>
                <div>☁️ <span class="font-medium text-gray-500">昼:</span> <%= truncate(record.lunch_memo, length: 15) %></div>
              <% end %>
              <% if record.dinner_memo.present? %>
                <div>🌙 <span class="font-medium text-gray-500">夕:</span> <%= truncate(record.dinner_memo, length: 15) %></div>
              <% end %>
            </div>
          <% end %>

        </div>
      <% end %>
    </div>

    <!-- ページネーションリンクエリア -->
    <div class="flex justify-center pt-6">
      <%= pure_rails_pagination(@all_advice_records.count, @current_page, mypage_advices_path) %>
    </div>

  <% else %>
    <!-- 条件分岐: 検索結果が空、またはデータがまだ無い場合のプレースホルダー -->
    <div class="text-center py-16 bg-white rounded-xl border border-gray-100 shadow-sm">
      <div class="text-4xl mb-3">🔍</div>
      <p class="text-base font-semibold text-gray-900">該当するアドバイス履歴が見つかりません</p>
      <p class="text-sm text-gray-500 mt-1">キーワードを変えて検索するか、日々の記録を増やしていきましょう。</p>
    </div>
  <% end %>

</div>
