<header class="bg-white shadow-sm sticky top-0 z-50">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex justify-between items-center">
    <%= link_to "Health AI Coach", root_path, data: { turbo: false }, class: "text-xl font-extrabold text-blue-600 tracking-tight" %>
    
    <div class="flex items-center space-x-4">
      <% if user_signed_in? %>
        <%# --- ログイン中 --- %>
        <div class="relative">
          <button onclick="document.getElementById('user-menu').classList.toggle('hidden')" class="flex items-center text-sm font-medium text-gray-700 hover:text-blue-600 transition focus:outline-none">
            <span><%= current_user.name || "メニュー" %></span>
            <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          
          <%# ドロップダウンメニュー %>
          <div id="user-menu" class="hidden absolute right-0 mt-2 w-48 bg-white border border-gray-100 rounded-md shadow-lg py-1 z-50">
            <%= link_to "記録をつける", new_health_record_path, data: { turbo: false }, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50" %>
            <%= link_to "履歴とグラフ", health_records_path, data: { turbo: false }, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50" %>
            <%= link_to "アカウント設定", edit_user_registration_path, data: { turbo: false }, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50" %>
            <hr class="my-1 border-gray-100">
            
            <%# 💡 確実にログアウトを単体フォームで送信する（インラインでメニューを隠すJSを付与） %>
            <%= button_to "ログアウト", destroy_user_session_path, 
                method: :delete, 
                data: { turbo: false },
                onclick: "document.getElementById('user-menu').classList.add('hidden');",
                class: "block w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-gray-50 transition bg-transparent border-none cursor-pointer" %>
          </div>
        </div>
      <% else %>
        <%# --- 未ログイン --- %>
        <%= link_to "ログイン", new_user_session_path, data: { turbo: false }, class: "text-sm font-medium text-gray-600 hover:text-blue-600 transition" %>
        <%= link_to "新規登録", new_user_registration_path, data: { turbo: false }, class: "bg-blue-600 text-white px-4 py-2 rounded-md text-sm font-bold shadow-sm hover:bg-blue-700 transition" %>
      <% end %>
    </div>
  </nav>
</header>
