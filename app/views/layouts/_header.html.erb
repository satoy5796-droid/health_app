<header class="bg-white shadow-sm sticky top-0 z-50">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex justify-between items-center">
    <%= link_to "Health AI Coach", root_path, class: "text-xl font-extrabold text-blue-600 tracking-tight" %>
    
    <div class="flex items-center space-x-4">
      <% if user_signed_in? %>
        <div class="relative">
          <button onclick="document.getElementById('user-menu').classList.toggle('hidden')" class="flex items-center text-sm font-medium text-gray-700 hover:text-blue-600 transition">
            <span><%= current_user.name || "メニュー" %></span>
            <svg class="ml-1 h-4 w-4" fill="currentColor" viewBox="0 0 20 20"><path d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" /></svg>
          </button>
          <div id="user-menu" class="hidden absolute right-0 mt-2 w-48 bg-white border border-gray-100 rounded-md shadow-lg py-1 z-50">
            <%= link_to "記録をつける", new_health_record_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50" %>
            <%= link_to "履歴とグラフ", health_records_path, class: "block px-4 py-2 text-sm text-gray-700 hover:bg-gray-50" %>
            <hr class="my-1">
            <%= button_to "ログアウト", destroy_user_session_path, method: :delete, class: "block w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-gray-50" %>
          </div>
        </div>
      <% else %>
        <%= link_to "ログイン", new_user_session_path, class: "text-sm font-medium text-gray-600" %>
        <%= link_to "新規登録", new_user_registration_path, class: "bg-blue-600 text-white px-4 py-2 rounded-md text-sm font-bold shadow-sm" %>
      <% end %>
    </div>
  </nav>
</header>
