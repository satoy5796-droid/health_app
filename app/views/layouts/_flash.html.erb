<div class="fixed top-20 right-4 z-50 space-y-2 pointer-events-none">
  <% flash.each do |key, value| %>
    <% bg_color = key.to_s == "notice" ? "bg-green-500" : "bg-red-500" %>
    <div class="pointer-events-auto flex items-center p-4 text-white rounded-lg shadow-lg <%= bg_color %>" role="alert">
      <div class="text-sm font-medium mr-4"><%= value %></div>
      <button onclick="this.parentElement.remove()" class="text-white hover:text-gray-200 focus:outline-none">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
    </div>
  <% end %>
</div>
