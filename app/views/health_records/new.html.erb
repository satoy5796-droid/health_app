<!-- app/views/health_records/new.html.erb -->
<div class="max-w-3xl mx-auto py-6 space-y-6">
  
  <!-- 上部ヘッダーエリア -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 border-b border-gray-200 pb-5">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 tracking-tight">体調・睡眠の記録</h1>
      <p class="mt-1 text-sm text-gray-500">今日のヘルスケアデータを入力して、AIコーチからアドバイスを受け取りましょう。</p>
    </div>
    <%= link_to health_records_path, data: { turbo: false }, class: "inline-flex items-center text-sm font-semibold text-gray-600 hover:text-blue-600 transition self-start sm:self-center" do %>
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
      ダッシュボードに戻る
    <% end %>
  </div>

  <!-- フォーム本体の呼び出し -->
  <!-- ⭕ 修正ポイント: 以前の古い変数の干責を完全に防ぎ、コントローラーから渡された @health_record を安全に引き渡します -->
  <%= render "form", health_record: @health_record %>

</div>
