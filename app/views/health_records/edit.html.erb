<!-- app/views/health_records/edit.html.erb -->
<div class="max-w-3xl mx-auto py-6 space-y-6">
  
  <!-- 上部ヘッダーエリア -->
  <div class="flex items-center justify-between border-b border-gray-200 pb-5">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 tracking-tight">健康記録の編集</h1>
      <p class="mt-1 text-sm text-gray-500">選択した日の体調や睡眠時間、食事内容を修正します。</p>
    </div>
    <%= link_to health_records_path, data: { turbo: false }, class: "inline-flex items-center text-sm font-semibold text-gray-600 hover:text-blue-600 transition" do %>
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
      ダッシュボードに戻る
    <% end %>
  </div>

  <!-- フォーム本体の呼び出し -->
  <!-- ⭕ 修正ポイント: 以前の古い変数の干渉を完全に防ぎ、コントローラーから渡された @health_record を安全に引き渡します -->
  <%= render "form", health_record: @health_record %>

  <!-- 下部アクション -->
  <div class="flex justify-center pt-4">
    <%= link_to "この記録の詳細を表示", health_record_path(@health_record), data: { turbo: false }, class: "text-sm font-medium text-gray-500 hover:text-gray-700 underline" %>
  </div>

</div>
