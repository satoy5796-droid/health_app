<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-800">健康記録を編集する</h1>
    <%= link_to "この記録を見る", health_record_path(@health_record), class: "text-sm text-blue-600 hover:underline" %>
  </div>

  <div class="bg-white shadow-sm rounded-xl p-6 md:p-8 border border-gray-100">
    <%= render "form", health_record: @health_record %>
  </div>

  <%= link_to "履歴に戻る", health_records_path, class: "block mt-6 text-sm text-gray-500 hover:text-blue-600 w-fit" %>
</div>
