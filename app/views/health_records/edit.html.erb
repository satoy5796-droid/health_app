<% content_for :title, "Editing health record" %>

<div class="md:w-2/3 w-full">
  <h1 class="font-bold text-4xl">Editing health record</h1>

  <%= render "form", health_record: @health_record %>

  <%= link_to "Show this health record", @health_record, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
  <%= link_to "Back to health records", health_records_path, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
</div>
