<% if user_signed_in? %>
  <% # ========================================== %>
  <% # 1. ログイン中の画面（既存のグラフとテーブル） %>
  <% # ========================================== %>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <%= turbo_frame_tag "health_chart_frame" do %>
      <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-gray-800">健康記録グラフ</h1>
        
        <!-- 期間切り替えボタン -->
        <div class="inline-flex rounded-md shadow-sm">
          <%= link_to "1週間", health_records_path(range: 'week'), 
              class: "px-4 py-2 text-sm font-medium border rounded-l-lg #{params[:range] != 'month' ? 'bg-blue-600 text-white border-blue-600' : 'bg-white text-gray-700 border-gray-200 hover:bg-gray-50'}" %>
          <%= link_to "1ヶ月", health_records_path(range: 'month'), 
              class: "px-4 py-2 text-sm font-medium border rounded-r-lg #{params[:range] == 'month' ? 'bg-blue-600 text-white border-blue-600' : 'bg-white text-gray-700 border-gray-200 hover:bg-gray-50'}" %>
        </div>
      </div>

      <!-- 複合グラフ -->
      <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 mb-10">
        <%# データを配列形式で渡し、libraryオプションで2番目の系列(体調スコア)を折れ線グラフ(line)にします %>
        <%= column_chart [
          { name: "睡眠時間(h)", data: @health_records.pluck(:recorded_on, :sleep_time) },
          { name: "体調スコア(1-5)", data: @health_records.pluck(:recorded_on, :condition) }
        ], 
        ytitle: "時間 / スコア",
        library: {
          series: {
            1 => { type: "line" } # 0から数えて1番目（2列目）のデータを折れ線に変える指示
          }
        } %>
      </div>
    <% end %>

    <!-- 記録するボタン -->
    <div class="flex justify-end mb-6">
      <%= link_to "今日の記録をつける", new_health_record_path, class: "bg-blue-600 text-white px-6 py-2 rounded-full font-bold shadow-md hover:bg-blue-700 transition" %>
    </div>
    
    <!-- 履歴テーブル -->
    <div class="mt-8 overflow-hidden shadow ring-1 ring-black ring-opacity-5 md:rounded-lg">
      <table class="min-w-full divide-y divide-gray-300">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">日付</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">体調</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider md:table-cell hidden">食事（夕食）</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">操作</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-gray-200">
          <% @health_records.each do |record| %>
            <tr class="hover:bg-gray-50 transition">
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900"><%= record.recorded_on %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= "⭐" * record.condition %></td>
              <td class="px-6 py-4 text-sm text-gray-500 md:table-cell hidden truncate max-w-xs"><%= record.dinner_memo %></td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <%= link_to "詳細", health_record_path(record), class: "text-blue-600 hover:text-blue-900 mr-3" %>
                <%= link_to "編集", edit_health_record_path(record), class: "text-gray-600 hover:text-gray-900" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

<% else %>
  <% # ========================================== %>
  <% # 2. 未ログイン・ログアウト直後の画面（新設） %>
  <% # ========================================== %>
  <div class="max-w-md mx-auto my-12 p-8 bg-white rounded-xl shadow-md border border-gray-100 text-center">
    <div class="inline-flex p-3 bg-blue-50 rounded-full text-blue-600 mb-4">
      <svg xmlns="w3.org" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-8 h-8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
      </svg>
    </div>
    <h1 class="text-2xl font-extrabold text-blue-600 mb-4">Health AI Coach</h1>
    <p class="text-gray-600 text-sm mb-8 leading-relaxed">
      日々の体調や睡眠時間を記録し、AIからパーソナルな健康アドバイスを受け取りましょう。
    </p>
    <div class="space-y-3">
      <%= button_to "ゲストとして利用開始", users_guest_sign_in_path, method: :post, data: { turbo: false }, class: "block w-full text-center bg-green-600 text-white py-3 rounded-md font-bold shadow-sm hover:bg-green-700 transition" %>
      <%= link_to "アカウントにログイン", new_user_session_path, data: { turbo: false }, class: "block w-full text-center bg-blue-600 text-white py-3 rounded-md font-bold shadow-sm hover:bg-blue-700 transition" %>
      <%= link_to "新しくアカウントを登録", new_user_registration_path, data: { turbo: false }, class: "block w-full text-center text-sm font-semibold text-gray-500 hover:text-blue-600 transition pt-2" %>
    </div>
  </div>
<% end %>
