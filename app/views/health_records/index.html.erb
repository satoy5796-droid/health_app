<div class="max-w-6xl mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-800">健康記録グラフ</h1>
    
    <!-- 期間切り替えボタン -->
    <div class="inline-flex rounded-md shadow-sm">
      <%= link_to "1週間", health_records_path(range: 'week'), 
          class: "px-4 py-2 text-sm font-medium border rounded-l-lg #{params[:range] != 'month' ? 'bg-blue-600 text-white border-blue-600' : 'bg-white text-gray-700 border-gray-200 hover:bg-gray-50'}" %>
      <%= link_to "1ヶ月", health_records_path(range: 'month'), 
          class: "px-4 py-2 text-sm font-medium border rounded-r-lg #{params[:range] == 'month' ? 'bg-blue-600 text-white border-blue-600' : 'bg-white text-gray-700 border-gray-200 hover:bg-gray-50'}" %>
    </div>
  </div>

  <!-- 複合グラフ -->
  <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 mb-10">
    <%= column_chart [
      { name: "睡眠時間(h)", data: @health_records.pluck(:recorded_on, :sleep_time) },
      { name: "体調スコア(1-5)", data: @health_records.pluck(:recorded_on, :condition), library: { type: "line", yAxisID: "y-condition" } }
    ], 
    ytitle: "時間", 
    library: {
      scales: {
        "y-condition": { position: "right", title: { display: true, text: "体調スコア" }, min: 0, max: 5 }
      }
    } %>
  </div>

  <!-- 記録するボタン -->
  <div class="flex justify-end mb-6">
    <%= link_to "今日の記録をつける", new_health_record_path, class: "bg-blue-600 text-white px-6 py-2 rounded-full font-bold shadow-md hover:bg-blue-700 transition" %>
  </div>
  
  <%# 記録一覧テーブルはここより下に続く... %>
</div>
