<div class="max-w-4xl mx-auto px-4 py-8">
  <!-- ヘッダーエリア -->
  <div class="flex justify-between items-center mb-8 border-b pb-4">
    <div>
      <p class="text-sm font-medium text-gray-500">Health AI Coach</p>
      <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight"><%= @health_record.recorded_on %> の記録</h1>
    </div>
    <div class="flex space-x-3">
      <%= link_to "編集する", edit_health_record_path(@health_record), class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 shadow-sm" %>
      <%= button_to "削除", health_record_path(@health_record), method: :delete, form: { data: { turbo_confirm: "本当に削除しますか？" } }, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-red-600 hover:bg-red-700 shadow-sm" %>
    </div>
  </div>

  <!-- 数値データカード（2列） -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 flex items-center justify-between">
      <div>
        <p class="text-sm font-medium text-gray-500 mb-1">今日の体調</p>
        <p class="text-3xl font-bold text-gray-900"><%= "⭐" * @health_record.condition %></p>
      </div>
      <span class="text-3xl">😊</span>
    </div>
    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 flex items-center justify-between">
      <div>
        <p class="text-sm font-medium text-gray-500 mb-1">睡眠時間</p>
        <p class="text-3xl font-bold text-gray-900"><%= @health_record.sleep_time %> <span class="text-lg font-medium text-gray-500">時間</span></p>
      </div>
      <span class="text-3xl">🌙</span>
    </div>
  </div>

  <!-- AIアドバイス（主役カード） -->
  <% # 1. サーバーからのリアルタイム更新（WebSocket）を受信するアンテナを設置 %>
<%= turbo_stream_from "health_record_#{@health_record.id}_advice_channel" %>

<div class="bg-gradient-to-r from-blue-50 to-indigo-50 p-6 rounded-xl border border-blue-100 mt-8">
  <h3 class="text-sm font-bold text-blue-800 tracking-wider uppercase mb-3 flex items-center">
    <span>🤖 AI健康管理コーチのアドバイス</span>
  </h3>

  <% # 2. Jobからピンポイントで中身を書き換えるための固定の器（ID付きのdiv） %>
  <div id="ai_advice_box_<%= @health_record.id %>" class="min-h-[60px] flex items-center">
    <% if @health_record.ai_advice.present? %>
      <% # すでにアドバイスが存在する場合はそのまま表示 %>
      <%= render "health_records/ai_advice_content", health_record: @health_record %>
    <% else %>
      <% # まだ無い、または生成中の場合は、Tailwindの「animate-pulse」でリッチなローディングを表示 %>
      <div class="w-full flex items-center space-x-3 text-gray-500 text-sm animate-pulse">
        <svg class="animate-spin h-5 w-5 text-blue-600" xmlns="w3.org" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        <span class="font-medium text-blue-700">AIコーチが今日のデータを解析してアドバイスを考えています...</span>
      </div>
    <% end %>
  </div>
</div>


  <!-- 食事の記録（3列） -->
  <div class="bg-white p-6 md:p-8 rounded-2xl shadow-sm border border-gray-100">
    <h2 class="text-lg font-bold text-gray-900 border-b pb-3 mb-6 flex items-center">
      <span class="mr-2">🍽️</span> 食事の振り返り
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-orange-50/50 p-4 rounded-xl border border-orange-100">
        <p class="font-bold text-orange-700 mb-2 flex items-center">☀️ 朝食</p>
        <p class="text-gray-700 text-sm whitespace-pre-wrap"><%= @health_record.breakfast_memo.presence || "（記録なし）" %></p>
      </div>
      <div class="bg-green-50/50 p-4 rounded-xl border border-green-100">
        <p class="font-bold text-green-700 mb-2 flex items-center">☁️ 昼食</p>
        <p class="text-gray-700 text-sm whitespace-pre-wrap"><%= @health_record.lunch_memo.presence || "（記録なし）" %></p>
      </div>
      <div class="bg-indigo-50/50 p-4 rounded-xl border border-indigo-100">
        <p class="font-bold text-indigo-700 mb-2 flex items-center">🌙 夕食</p>
        <p class="text-gray-700 text-sm whitespace-pre-wrap"><%= @health_record.dinner_memo.presence || "（記録なし）" %></p>
      </div>
    </div>
  </div>

  <%= link_to "履歴とグラフに戻る", health_records_path, class: "inline-block mt-8 text-sm text-gray-500 hover:text-blue-600 transition" %>
</div>
